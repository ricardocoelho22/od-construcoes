---
interface Props {
  titulo: string;
  subtitulo: string;
  lista: { titulo: string; descricao: string; pasta: string; imagens: number }[];
  facebook: string;
}

const { titulo, subtitulo, lista, facebook } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<section id="trabalhos" class="relative py-24 md:py-32 bg-surface overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-10">
    <div class="reveal flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16">
      <div>
        <p class="text-accent-strong text-sm tracking-[0.3em] uppercase font-medium mb-4">Portfólio</p>
        <h2 class="font-display text-4xl md:text-5xl lg:text-6xl text-heading leading-tight">
          {titulo}
        </h2>
      </div>
      <p class="text-subtle text-lg max-w-md">{subtitulo}</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 stagger">
      {lista.map((t, i) => (
        <div
          class="reveal group relative overflow-hidden aspect-[4/3] bg-navy-200 cursor-pointer"
          data-gallery-folder={t.pasta}
          data-gallery-count={t.imagens}
          data-gallery-title={t.titulo}
        >
          <img
            src={`${base}images/portfolio/${t.pasta}/1.jpg`}
            alt={t.titulo}
            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 ease-out"
            loading="lazy"
          />
          <!-- Overlay gradient -->
          <div class="absolute inset-0 bg-gradient-to-t from-surface-inverse/90 via-surface-inverse/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <!-- Text -->
          <div class="absolute inset-x-0 bottom-0 p-6 translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-500">
            <span class="text-accent-soft text-xs tracking-[0.2em] uppercase font-medium">{t.descricao}</span>
            <h3 class="text-white font-display text-xl mt-1">{t.titulo}</h3>
          </div>
          <!-- Photo count badge -->
          {t.imagens > 1 && (
            <div class="absolute top-4 left-4 bg-surface-inverse/70 backdrop-blur-sm text-white text-xs font-medium px-3 py-1.5 flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              {t.imagens}
            </div>
          )}
          <!-- Corner accent -->
          <div class="absolute top-4 right-4 w-8 h-8 border-t-2 border-r-2 border-accent opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-100"></div>
        </div>
      ))}
    </div>

    <!-- Facebook CTA -->
    <div class="reveal mt-12 md:mt-16 flex justify-center">
      <a
        href={facebook}
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center gap-3 text-subtle hover:text-accent-soft transition-colors duration-300"
      >
        <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
        </svg>
        <span class="text-sm tracking-[0.15em] uppercase font-medium">Veja mais trabalhos no Facebook</span>
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>

  <!-- Lightbox -->
  <div
    id="lightbox"
    class="fixed inset-0 z-[60] opacity-0 pointer-events-none transition-opacity duration-300"
    data-base={base}
    role="dialog"
    aria-modal="true"
    aria-label="Galeria de imagens"
  >
    <!-- Backdrop -->
    <div id="lightbox-backdrop" class="absolute inset-0 bg-surface-inverse/95 backdrop-blur-sm"></div>

    <!-- Close -->
    <button
      id="lightbox-close"
      class="absolute top-4 right-4 z-10 text-white/70 hover:text-accent-soft transition-colors p-2"
      aria-label="Fechar galeria"
    >
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Header -->
    <div class="absolute top-4 left-4 z-10">
      <h3 id="lightbox-title" class="font-display text-xl text-white"></h3>
      <p id="lightbox-counter" class="text-accent-soft text-sm tracking-wider mt-1"></p>
    </div>

    <!-- Main image -->
    <div class="absolute inset-0 flex items-center justify-center px-4 sm:px-16 py-20">
      <img
        id="lightbox-img"
        class="max-w-full max-h-full object-contain transition-all duration-300"
        alt=""
      />
    </div>

    <!-- Prev -->
    <button
      id="lightbox-prev"
      class="absolute left-2 sm:left-4 top-1/2 -translate-y-1/2 z-10 text-white/50 hover:text-accent-soft transition-colors p-3"
      aria-label="Imagem anterior"
    >
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    </button>

    <!-- Next -->
    <button
      id="lightbox-next"
      class="absolute right-2 sm:right-4 top-1/2 -translate-y-1/2 z-10 text-white/50 hover:text-accent-soft transition-colors p-3"
      aria-label="Imagem seguinte"
    >
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </button>

    <!-- Thumbnails -->
    <div id="lightbox-thumbs" class="absolute bottom-4 left-1/2 -translate-x-1/2 z-10 flex gap-2 overflow-x-auto max-w-[80vw] px-4 py-2"></div>
  </div>
</section>

<style is:global>
  #lightbox-img.switching {
    opacity: 0;
    transform: scale(0.97);
  }
</style>

<script>
  const lightbox = document.getElementById("lightbox");
  const img = document.getElementById("lightbox-img") as HTMLImageElement;
  const titleEl = document.getElementById("lightbox-title");
  const counterEl = document.getElementById("lightbox-counter");
  const closeBtn = document.getElementById("lightbox-close");
  const prevBtn = document.getElementById("lightbox-prev") as HTMLElement;
  const nextBtn = document.getElementById("lightbox-next") as HTMLElement;
  const backdrop = document.getElementById("lightbox-backdrop");
  const thumbsContainer = document.getElementById("lightbox-thumbs");

  const baseUrl = lightbox?.dataset.base || "/";

  let folder = "";
  let count = 0;
  let index = 1;
  let previouslyFocused: HTMLElement | null = null;

  function buildUrl(f: string, n: number): string {
    return `${baseUrl}images/portfolio/${f}/${n}.jpg`;
  }

  function open(galleryFolder: string, galleryCount: number, galleryTitle: string) {
    folder = galleryFolder;
    count = galleryCount;
    index = 1;
    previouslyFocused = document.activeElement as HTMLElement;

    document.body.style.overflow = "hidden";
    lightbox?.classList.remove("opacity-0", "pointer-events-none");
    lightbox?.classList.add("opacity-100", "pointer-events-auto");

    titleEl!.textContent = galleryTitle;
    updateImage();
    buildThumbnails();
    closeBtn?.focus();
  }

  function close() {
    lightbox?.classList.add("opacity-0", "pointer-events-none");
    lightbox?.classList.remove("opacity-100", "pointer-events-auto");
    document.body.style.overflow = "";
    previouslyFocused?.focus();
  }

  function updateImage() {
    img?.classList.add("switching");

    setTimeout(() => {
      img!.src = buildUrl(folder, index);
      img!.alt = `${titleEl?.textContent} - Imagem ${index} de ${count}`;
      counterEl!.textContent = `${index} / ${count}`;

      prevBtn.style.display = index <= 1 ? "none" : "";
      nextBtn.style.display = index >= count ? "none" : "";

      // Update thumbnail highlights
      thumbsContainer?.querySelectorAll("button").forEach((btn, i) => {
        const isActive = i + 1 === index;
        btn.classList.toggle("ring-2", isActive);
        btn.classList.toggle("ring-amber-400", isActive);
        btn.classList.toggle("opacity-100", isActive);
        btn.classList.toggle("opacity-40", !isActive);
      });

      img!.onload = () => {
        img?.classList.remove("switching");
        preload(index + 1);
        preload(index - 1);
      };

      // Fallback if image is cached (onload already fired)
      if (img!.complete) {
        img?.classList.remove("switching");
      }
    }, 150);
  }

  function next() {
    if (index < count) { index++; updateImage(); }
  }

  function prev() {
    if (index > 1) { index--; updateImage(); }
  }

  function buildThumbnails() {
    if (!thumbsContainer) return;
    thumbsContainer.innerHTML = "";
    if (count <= 1) return;

    for (let i = 1; i <= count; i++) {
      const btn = document.createElement("button");
      btn.className = `w-12 h-12 shrink-0 overflow-hidden transition-all duration-200 ${i === 1 ? "ring-2 ring-amber-400 opacity-100" : "opacity-40 hover:opacity-70"}`;
      btn.setAttribute("aria-label", `Imagem ${i}`);

      const thumbImg = document.createElement("img");
      thumbImg.src = buildUrl(folder, i);
      thumbImg.alt = "";
      thumbImg.className = "w-full h-full object-cover";
      thumbImg.loading = "lazy";

      btn.appendChild(thumbImg);
      btn.addEventListener("click", () => { index = i; updateImage(); });
      thumbsContainer.appendChild(btn);
    }
  }

  function preload(n: number) {
    if (n >= 1 && n <= count) {
      const link = document.createElement("link");
      link.rel = "prefetch";
      link.href = buildUrl(folder, n);
      document.head.appendChild(link);
    }
  }

  // Card click handlers
  document.querySelectorAll("[data-gallery-folder]").forEach((card) => {
    card.addEventListener("click", () => {
      const el = card as HTMLElement;
      open(el.dataset.galleryFolder!, parseInt(el.dataset.galleryCount!, 10), el.dataset.galleryTitle!);
    });
  });

  // Close handlers
  closeBtn?.addEventListener("click", close);
  backdrop?.addEventListener("click", close);

  // Keyboard
  document.addEventListener("keydown", (e) => {
    if (!lightbox?.classList.contains("opacity-100")) return;
    if (e.key === "Escape") close();
    else if (e.key === "ArrowRight") next();
    else if (e.key === "ArrowLeft") prev();
  });

  // Nav button clicks
  prevBtn?.addEventListener("click", (e) => { e.stopPropagation(); prev(); });
  nextBtn?.addEventListener("click", (e) => { e.stopPropagation(); next(); });

  // Touch swipe
  let touchStartX = 0;
  lightbox?.addEventListener("touchstart", (e) => {
    touchStartX = (e as TouchEvent).changedTouches[0].screenX;
  }, { passive: true });

  lightbox?.addEventListener("touchend", (e) => {
    const diff = touchStartX - (e as TouchEvent).changedTouches[0].screenX;
    if (Math.abs(diff) > 50) {
      if (diff > 0) next(); else prev();
    }
  });

  // Focus trap
  lightbox?.addEventListener("keydown", (e) => {
    if (e.key !== "Tab") return;
    const focusables = lightbox.querySelectorAll<HTMLElement>('button:not([style*="display: none"])');
    const first = focusables[0];
    const last = focusables[focusables.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault(); last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault(); first.focus();
    }
  });
</script>
