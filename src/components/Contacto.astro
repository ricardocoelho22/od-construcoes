---
interface Props {
  titulo: string;
  contacto: {
    telefones: string[];
    emails: string[];
    morada: string;
  };
  facebook: string;
}

const { titulo, contacto, facebook } = Astro.props;
---

<section id="contacto" class="relative py-24 md:py-32 bg-surface-inverse overflow-hidden">
  <!-- Grain -->
  <div class="absolute inset-0 grain"></div>

  <div class="relative max-w-7xl mx-auto px-6 sm:px-8 lg:px-10">
    <div class="reveal mb-16">
      <p class="text-accent-soft text-sm tracking-[0.3em] uppercase font-medium mb-4">Entre em Contacto</p>
      <h2 class="font-display text-4xl md:text-5xl lg:text-6xl text-white leading-tight">
        {titulo}
      </h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      <!-- Main CTAs — large and prominent -->
      <div class="lg:col-span-7 space-y-6">
        <!-- Phone CTA -->
        <div class="reveal bg-surface-inverse-raised/80 border border-white/5 p-6 md:p-8 hover:border-accent/30 transition-colors duration-500">
          <!-- Header row: icon + label -->
          <div class="flex items-center gap-4 mb-5">
            <div class="w-10 h-10 bg-accent flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-surface-inverse" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <p class="text-faint text-xs tracking-[0.2em] uppercase font-medium">Telefone</p>
          </div>

          <!-- Listed phone numbers -->
          <ul class="divide-y divide-white/5">
            {contacto.telefones.map((phone) => (
              <li>
                <a
                  href={`tel:${phone.replace(/\s/g, "")}`}
                  class="group flex items-center justify-between gap-4 py-3 first:pt-0 last:pb-0"
                >
                  <span class="text-2xl md:text-3xl font-display text-white group-hover:text-accent-soft transition-colors">
                    {phone}
                  </span>
                  <svg class="w-5 h-5 text-subtle group-hover:text-accent-soft group-hover:translate-x-1 transition-all shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Email CTA -->
        <div
          class="reveal bg-surface-inverse-raised/80 border border-white/5 p-6 md:p-8 hover:border-accent/30 transition-colors duration-500"
          style="transition-delay: 100ms"
        >
          <!-- Header row: icon + label -->
          <div class="flex items-center gap-4 mb-5">
            <div class="w-10 h-10 bg-accent flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-surface-inverse" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
            </div>
            <p class="text-faint text-xs tracking-[0.2em] uppercase font-medium">Email</p>
          </div>

          <!-- Listed emails -->
          <ul class="divide-y divide-white/5">
            {contacto.emails.map((email) => (
              <li>
                <a
                  href={`mailto:${email}`}
                  class="group flex items-center justify-between gap-4 py-3 first:pt-0 last:pb-0"
                >
                  <span class="min-w-0 text-base sm:text-lg md:text-2xl font-display text-white group-hover:text-accent-soft transition-colors break-words">
                    {email}
                  </span>
                  <svg class="w-5 h-5 text-subtle group-hover:text-accent-soft group-hover:translate-x-1 transition-all shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Sidebar — Location + Facebook -->
      <div class="lg:col-span-5 space-y-8 reveal" style="transition-delay: 200ms">
        <div class="border-l-2 border-accent/40 pl-6">
          <p class="text-faint text-xs tracking-[0.2em] uppercase font-medium mb-3">Localização</p>
          <p class="text-white leading-relaxed text-lg">{contacto.morada}</p>
        </div>

        <a
          href={facebook}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-4 border-l-2 border-accent/40 pl-6 hover:border-accent-soft transition-colors"
        >
          <div>
            <p class="text-faint text-xs tracking-[0.2em] uppercase font-medium mb-2">Siga-nos</p>
            <div class="flex items-center gap-3">
              <svg class="w-6 h-6 text-white group-hover:text-accent-soft transition-colors" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
              </svg>
              <span class="text-white group-hover:text-accent-soft transition-colors text-lg">Facebook</span>
            </div>
          </div>
        </a>

        <div class="border-l-2 border-accent/40 pl-6">
          <p class="text-faint text-xs tracking-[0.2em] uppercase font-medium mb-3">Orçamento</p>
          <p class="text-accent-soft font-display text-xl">Grátis e sem compromisso</p>
        </div>
      </div>
    </div>
  </div>
</section>
