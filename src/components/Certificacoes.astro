---
interface Props {
  titulo: string;
  subtitulo: string;
  lista: { nome: string; descricao: string; icone: string }[];
}

const { titulo, subtitulo, lista } = Astro.props;

const icons: Record<string, string> = {
  building:
    "M3 21V3h8v4h10v14H3zm2-2h4v-2H5v2zm0-4h4v-2H5v2zm0-4h4V9H5v2zm0-4h4V5H5v2zm6 12h8v-2h-2v-2h2v-2h-2v-2h2V9h-8v12zm2-2v-2h2v2h-2zm0-4v-2h2v2h-2z",
  paintbrush:
    "M18.41 2.59a2 2 0 0 0-2.83 0L8 10.17V14h3.83l7.58-7.59a2 2 0 0 0 0-2.82zM4 18v2h6l-2-2H4zm10.12-12.71L11 8.41 12.59 10l3.12-3.12-1.59-1.59z",
  restore:
    "M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm-4-8l4-4v3h4v2h-4v3l-4-4z",
  roof: "M12 3L2 12h3v8h14v-8h3L12 3zm0 3.19L18 12v6H6v-6l6-5.81z",
  wrench:
    "M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z",
  sparkle:
    "M12 2L9.19 8.63 2 9.24l5.46 4.73L5.82 21 12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2z",
  shield:
    "M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z",
};
---

<section id="certificacoes" class="relative py-24 md:py-32 bg-surface-raised overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-10">
    <div class="reveal text-center mb-16 max-w-2xl mx-auto">
      <p class="text-accent-strong text-sm tracking-[0.3em] uppercase font-medium mb-4">Formação Técnica</p>
      <h2 class="font-display text-4xl md:text-5xl text-heading leading-tight mb-6">
        {titulo}
      </h2>
      <p class="text-subtle text-lg">{subtitulo}</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 stagger">
      {lista.map((c, i) => (
        <div class="reveal group relative bg-surface border border-line p-8 hover:border-accent/40 hover:bg-accent-faint/30 transition-all duration-500">
          <!-- Number indicator -->
          <span class="font-display text-6xl text-pale group-hover:text-amber-200 transition-colors duration-500 absolute -top-2 right-4 leading-none">
            {String(i + 1).padStart(2, '0')}
          </span>

          <div class="relative">
            <div class="w-12 h-12 mb-6 text-accent">
              <svg class="w-full h-full" fill="currentColor" viewBox="0 0 24 24">
                <path d={icons[c.icone] || icons.shield} />
              </svg>
            </div>

            <h3 class="font-bold text-heading mb-3 text-lg">{c.nome}</h3>
            <p class="text-sm text-muted leading-relaxed">{c.descricao}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
