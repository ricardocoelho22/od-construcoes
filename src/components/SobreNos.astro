---
interface Props {
  titulo: string;
  paragrafos: string[];
  destaques: { valor: string; texto: string }[];
}

const { titulo, paragrafos, destaques } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<section id="sobre" class="relative bg-stone-50 overflow-hidden">
  <!-- About content -->
  <div class="relative py-24 md:py-32">
    <div class="absolute inset-0 accent-stripe opacity-50"></div>

    <div class="relative max-w-7xl mx-auto px-6 sm:px-8 lg:px-10">
      <!-- Section label -->
      <div class="reveal mb-16">
        <p class="text-amber-600 text-sm tracking-[0.3em] uppercase font-medium mb-4">Quem Somos</p>
        <h2 class="font-display text-4xl md:text-5xl lg:text-6xl text-navy-900 leading-tight">
          {titulo}
        </h2>
        <span class="block w-20 h-1 bg-amber-500 mt-6"></span>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
        <!-- Text — takes 7 columns -->
        <div class="lg:col-span-7 space-y-6">
          {paragrafos.map((p, i) => (
            <p class="reveal text-navy-600 text-lg leading-relaxed" style={`transition-delay: ${i * 100}ms`}>
              {p}
            </p>
          ))}
        </div>

        <!-- Image — takes 5 columns -->
        <div class="lg:col-span-5 reveal" style="transition-delay: 200ms">
          <div class="relative">
            <div class="absolute -top-4 -right-4 w-full h-full border-2 border-amber-500/30 hidden lg:block"></div>
            <img
              src={`${base}images/about.jpg`}
              alt="Equipa OD. Construções"
              class="relative w-full object-cover aspect-[4/3] grayscale-[30%] hover:grayscale-0 transition-all duration-700"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- European map strip -->
  <div class="relative bg-navy-950 grain overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-amber-500/5 via-transparent to-amber-500/5"></div>

    <div class="relative max-w-7xl mx-auto px-6 sm:px-8 lg:px-10 py-16 md:py-20">
      <div class="reveal">
        <p class="text-amber-400 text-sm tracking-[0.3em] uppercase font-medium mb-8 text-center">Experiência Internacional</p>
        <h3 class="font-display text-3xl md:text-4xl text-white text-center mb-12 max-w-2xl mx-auto leading-snug">
          Experiência construída por toda a <span class="text-amber-400">Europa</span>
        </h3>

        <!-- Europe map -->
        <div class="max-w-3xl mx-auto">
          <svg viewBox="0 0 940 720" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto" aria-hidden="true">
            <!-- Background countries -->
            <g>
              <!-- Spain -->
              <path class="map-country-bg" d="M 51 521 L 174 521 L 262 528 L 260 567 L 209 613 L 185 655 L 109 665 L 48 611 Z"/>
              <!-- Ireland -->
              <path class="map-country-bg" d="M 26 378 L 103 319 L 106 369 L 60 378 Z"/>
              <!-- United Kingdom -->
              <path class="map-country-bg" d="M 108 404 L 234 380 L 214 342 L 174 297 L 116 246 L 77 258 L 120 332 L 150 378 Z"/>
              <!-- Netherlands -->
              <path class="map-country-bg" d="M 263 342 L 328 345 L 327 373 L 306 384 L 263 380 Z"/>
              <!-- Belgium -->
              <path class="map-country-bg" d="M 248 386 L 309 391 L 311 415 L 287 415 L 248 406 Z"/>
              <!-- Switzerland -->
              <path class="map-country-bg" d="M 308 449 L 385 447 L 376 480 L 333 482 Z"/>
              <!-- Austria -->
              <path class="map-country-bg" d="M 367 438 L 499 443 L 499 473 L 434 473 L 376 462 Z"/>
              <!-- Italy -->
              <path class="map-country-bg" d="M 325 521 L 342 517 L 444 484 L 470 558 L 521 589 L 479 628 L 472 637 L 427 637 L 393 618 L 333 522 Z"/>
              <!-- Czech Republic -->
              <path class="map-country-bg" d="M 412 390 L 513 393 L 513 432 L 419 432 Z"/>
              <!-- Slovakia -->
              <path class="map-country-bg" d="M 496 415 L 586 415 L 586 443 L 499 443 Z"/>
              <!-- Poland -->
              <path class="map-country-bg" d="M 446 325 L 598 325 L 614 397 L 513 406 L 513 393 L 446 390 Z"/>
              <!-- Hungary -->
              <path class="map-country-bg" d="M 482 443 L 586 443 L 586 484 L 513 484 L 482 462 Z"/>
              <!-- Norway -->
              <path class="map-country-bg" d="M 291 258 L 393 306 L 513 266 L 684 185 L 692 129 L 718 28 L 649 19 L 461 43 L 342 166 Z"/>
              <!-- Sweden -->
              <path class="map-country-bg" d="M 393 306 L 513 306 L 582 286 L 615 129 L 582 65 L 513 65 L 427 111 L 393 166 L 291 258 Z"/>
              <!-- Finland -->
              <path class="map-country-bg" d="M 582 286 L 615 222 L 667 212 L 709 166 L 709 46 L 667 35 L 615 120 L 582 65 Z"/>
              <!-- Denmark -->
              <path class="map-country-bg" d="M 344 314 L 422 306 L 422 268 L 350 262 Z"/>
              <!-- Greece -->
              <path class="map-country-bg" d="M 547 558 L 649 558 L 658 628 L 588 646 L 582 657 L 547 646 Z"/>
              <!-- Croatia -->
              <path class="map-country-bg" d="M 438 471 L 525 484 L 504 541 L 441 495 Z"/>
              <!-- Serbia -->
              <path class="map-country-bg" d="M 530 476 L 590 476 L 590 535 L 530 535 Z"/>
              <!-- Bulgaria -->
              <path class="map-country-bg" d="M 588 513 L 692 519 L 684 569 L 607 565 L 588 545 Z"/>
              <!-- Ukraine (western) -->
              <path class="map-country-bg" d="M 586 364 L 769 364 L 837 462 L 713 484 L 588 439 Z"/>
            </g>
            <!-- Highlighted countries (on top) -->
            <g>
              <!-- Portugal -->
              <path class="map-country-highlight" d="M 99 552 L 99 646 L 53 646 L 43 615 L 55 552 Z"/>
              <!-- France -->
              <path class="map-country-highlight" d="M 123 436 L 248 386 L 345 443 L 337 522 L 260 528 L 174 524 Z"/>
              <!-- Germany -->
              <path class="map-country-highlight" d="M 309 373 L 350 316 L 444 323 L 455 388 L 414 449 L 338 452 L 311 415 Z"/>
              <!-- Romania -->
              <path class="map-country-highlight" d="M 588 439 L 660 436 L 713 484 L 692 522 L 627 522 L 588 513 Z"/>
            </g>
          </svg>
        </div>
      </div>
    </div>
  </div>

  <!-- Stats banner -->
  <div class="relative bg-navy-900">
    <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-10">
      <div class="reveal grid grid-cols-1 sm:grid-cols-2 divide-y sm:divide-y-0 sm:divide-x divide-white/10">
        {destaques.filter((_, i) => i > 0).map((d) => (
          <div class="py-10 md:py-12 sm:first:pl-0 sm:pl-12 sm:last:pr-0 sm:pr-12">
            <div class="flex items-baseline gap-4">
              <span class="font-display text-5xl md:text-6xl text-amber-400 leading-none">{d.valor}</span>
              <span class="text-navy-300 text-sm uppercase tracking-[0.2em] font-medium">{d.texto}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
