---
interface Props {
  copyright: string;
  facebook: string;
}

const { copyright, facebook } = Astro.props;
---

<footer class="bg-navy-950 border-t border-white/5">
  <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-10 py-10">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
      <!-- Logo + copyright -->
      <div class="flex items-center gap-4">
        <span class="font-display text-lg text-white">
          <span class="text-amber-400">OD.</span> Construções
        </span>
        <span class="w-px h-4 bg-white/10 hidden sm:block"></span>
        <p class="text-navy-500 text-sm">{copyright}</p>
      </div>

      <div class="flex items-center gap-8">
        <a
          href="#inicio"
          class="text-navy-500 hover:text-amber-400 transition-colors text-sm tracking-wide uppercase"
        >
          Topo
        </a>
        <a
          href={facebook}
          target="_blank"
          rel="noopener noreferrer"
          class="text-navy-500 hover:text-amber-400 transition-colors"
          aria-label="Facebook"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
